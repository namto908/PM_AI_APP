# Database
DATABASE_URL=postgresql+asyncpg://taskops:taskops_secret@localhost:5432/taskops_db

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your_super_secret_key_here_min_32_chars
JWT_EXPIRE_MINUTES=1440

# AI Provider (Gemini — executor)
GEMINI_API_KEY=ADD_KEY_HERE
GEMINI_MODEL=gemma-3-27b-it

# App
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=["http://localhost:5173"]

# Planner / Reasoning models
# ACTIVE_PLANNER: "none" | "gemma" | "grok"
ACTIVE_PLANNER=gemma
PLANNER_MODEL=gemma-4-31b-it
XAI_API_KEY=ADD_KEY_HERE
XAI_MODEL=grok-4-1-fast-reasoning

# Default Superadmin
SUPERADMIN_IDENTIFIER=
SUPERADMIN_PASSWORD=
